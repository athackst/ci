name: PR Bump

on:
  pull_request:
    types:
      - labeled
      - unlabeled

jobs:
  pr-bump:
    if: ${{ github.event.pull_request.head.repo.full_name == github.repository && github.actor != 'dependabot[bot]' }}
    permissions:
      contents: write
      pull-requests: write
    uses: athackst/ci/.github/workflows/bump.yml@main
    with:
      bump-script: [[ bump_script_path ]]
    secrets:
      token: ${{ secrets.CI_BOT_TOKEN }}
